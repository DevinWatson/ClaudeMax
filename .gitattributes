# Normalize line endings: store text as LF in the repo, regardless of OS.
* text=auto eol=lf

# Explicitly treat the agent/skill/tooling sources as LF text.
*.md   text eol=lf
*.json text eol=lf
*.ts   text eol=lf
*.mjs  text eol=lf
*.yml  text eol=lf

# Binary assets should never be normalized.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
